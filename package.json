{
  "name": "file-transfer",
  "version": "1.0.0",
  "main": "backend/server.js",
  "scripts": {
    "server": "node backend/server.js",
    "server:dev": "node --watch --watch-path=backend backend/server.js",
    "client": "vite --config frontend/vite.config.mjs",
    "dev": "npm run dev:local",
    "dev:local": "concurrently \"npm run server:dev\" \"node backend/monitorWorker.js\" \"npm run client\"",
    "build": "vite build --config frontend/vite.config.mjs",
    "preview": "vite preview --config frontend/vite.config.mjs",
    "lint:frontend": "eslint frontend --config frontend/eslint.config.mjs --no-config-lookup",
    "deploy": "bash scripts/deploy.sh",
    "deploy:skip-install": "SKIP_INSTALL=1 bash scripts/deploy.sh",
    "test": "mocha --recursive --timeout 5000",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop ecosystem.config.js",
    "pm2:restart": "npx pm2 restart ecosystem.config.js",
    "pm2:logs": "npx pm2 logs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.1.4",
    "express": "^5.2.1",
    "ffmpeg-min-local": "file:../../../Volumes/data/ffmpeg/release",
    "lucide-react": "^0.577.0",
    "mediasoup": "^3.19.3",
    "mediasoup-client": "^3.18.7",
    "multer": "^2.1.0",
    "node-mpv": "^1.5.0",
    "pdfkit": "^0.17.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "mocha": "^10.2.0",
    "pm2": "^5.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
